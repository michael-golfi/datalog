Edge("class/EpisodeOfCare", "onto/preferred_label", "Episode Of Care").
Edge("class/EpisodeOfCare", "onto/instance_of", "class/Thing").
Edge("class/EpisodeOfCare", "onto/subclass_of", "class/Thing").

