Edge("class/UserConditionAssertion", "onto/instance_of", "class/Thing").
Edge("class/UserConditionAssertion", "onto/subclass_of", "class/UserClinicalAssertion").
Edge("class/UserMedicationAssertion", "onto/preferred_label", "User Medication Assertion").
Edge("class/UserMedicationAssertion", "onto/instance_of", "class/Thing").
Edge("class/UserMedicationAssertion", "onto/subclass_of", "class/UserClinicalAssertion").
Edge("class/UserIndicationMatch", "onto/preferred_label", "User Indication Match").
Edge("class/UserIndicationMatch", "onto/instance_of", "class/Thing").
Edge("class/UserIndicationMatch", "onto/subclass_of", "class/UserClinicalAssertion").
Edge("class/UserContraindicationRisk", "onto/preferred_label", "User Contraindication Risk").
