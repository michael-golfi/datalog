Edge("class/Contraindication", "onto/subclass_of", "class/ClinicalRelationship").
Edge("class/ComorbidityAssociation", "onto/preferred_label", "Comorbidity Association").
Edge("class/ComorbidityAssociation", "onto/instance_of", "class/Thing").
Edge("class/ComorbidityAssociation", "onto/subclass_of", "class/ClinicalRelationship").
Edge("class/ExternalMapping", "onto/preferred_label", "External Mapping").
Edge("class/ExternalMapping", "onto/instance_of", "class/Thing").
Edge("class/ExternalMapping", "onto/subclass_of", "class/Thing").
Edge("class/Vocabulary", "onto/preferred_label", "External Vocabulary").
Edge("class/Vocabulary", "onto/instance_of", "class/Thing").
