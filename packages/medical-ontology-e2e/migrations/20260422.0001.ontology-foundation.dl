% === Clinical Ontology Foundation v2 ===
% Binary predicates remain for stable taxonomy and scalar metadata.
% Compounds represent n-ary clinical relations; metadata is attached to the compound cid.

% --- Core ontology predicates ---
DefPred("onto/preferred_label", "1", "liquid/node", "0", "liquid/string").
DefPred("onto/description", "1", "liquid/node", "0", "liquid/string").
DefPred("onto/subclass_of", "0", "liquid/node", "0", "liquid/node").
DefPred("onto/instance_of", "0", "liquid/node", "0", "liquid/node").
DefPred("onto/semantic_group", "1", "liquid/node", "0", "liquid/string").
DefPred("onto/status", "1", "liquid/node", "0", "liquid/string").

% --- Clinical relationship metadata predicates ---
DefPred("clinical/relationship_kind", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/evidence_source", "0", "liquid/node", "0", "liquid/node").
DefPred("clinical/evidence_level", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/action", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/severity", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/directionality", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/confidence", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/as_of_date", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/normalized_pair_key", "1", "liquid/node", "0", "liquid/string").
DefPred("clinical/clinical_note", "1", "liquid/node", "0", "liquid/string").

% --- External terminology mapping predicates ---
DefPred("mapping/url", "1", "liquid/node", "0", "liquid/string").
DefPred("mapping/source", "1", "liquid/node", "0", "liquid/string").
DefPred("mapping/license_scope", "1", "liquid/node", "0", "liquid/string").
DefPred("mapping/version", "1", "liquid/node", "0", "liquid/string").
DefPred("mapping/scope", "1", "liquid/node", "0", "liquid/string").
DefPred("mapping/as_of_date", "1", "liquid/node", "0", "liquid/string").

% --- User clinical assertion predicates ---
DefPred("user/status", "1", "liquid/node", "0", "liquid/string").
DefPred("user/source", "1", "liquid/node", "0", "liquid/string").
DefPred("user/observed_at", "1", "liquid/node", "0", "liquid/string").
DefPred("user/onset_date", "1", "liquid/node", "0", "liquid/string").
DefPred("user/start_date", "1", "liquid/node", "0", "liquid/string").
DefPred("user/end_date", "1", "liquid/node", "0", "liquid/string").
DefPred("user/dose_text", "1", "liquid/node", "0", "liquid/string").
DefPred("user/route", "1", "liquid/node", "0", "liquid/string").
DefPred("user/frequency", "1", "liquid/node", "0", "liquid/string").
DefPred("user/certainty", "1", "liquid/node", "0", "liquid/string").
DefPred("user/adherence_status", "1", "liquid/node", "0", "liquid/string").

% --- Compound identity definitions ---
% A mapping is identified by the local concept, external vocabulary, and external code.
DefCompound("ExternalMapping", "mapping/concept", "0", "liquid/node").
DefCompound("ExternalMapping", "mapping/vocabulary", "0", "liquid/node").
DefCompound("ExternalMapping", "mapping/code", "0", "liquid/string").
Edge("ExternalMapping", "liquid/mutable", "false").

% A medication-class membership is an n-ary relationship node, not just a binary edge.
DefCompound("MedicationClassMembership", "clinical/medication", "0", "liquid/node").
DefCompound("MedicationClassMembership", "clinical/drug_class", "0", "liquid/node").
Edge("MedicationClassMembership", "liquid/mutable", "false").

% A medication indication joins a medication ingredient and a target condition.
DefCompound("Indication", "clinical/medication", "0", "liquid/node").
DefCompound("Indication", "clinical/condition", "0", "liquid/node").
Edge("Indication", "liquid/mutable", "false").

% A contraindication joins a medication ingredient and a patient condition/risk state.
DefCompound("Contraindication", "clinical/medication", "0", "liquid/node").
DefCompound("Contraindication", "clinical/condition", "0", "liquid/node").
Edge("Contraindication", "liquid/mutable", "false").

% Symmetric comorbidity is represented once using a normalized condition pair.
DefCompound("ComorbidityAssociation", "clinical/condition_a", "0", "liquid/node").
DefCompound("ComorbidityAssociation", "clinical/condition_b", "0", "liquid/node").
Edge("ComorbidityAssociation", "liquid/mutable", "false").

% User-level assertions are separated from canonical ontology facts.
DefCompound("UserConditionAssertion", "user/profile", "0", "liquid/node").
DefCompound("UserConditionAssertion", "user/episode", "0", "liquid/node").
DefCompound("UserConditionAssertion", "clinical/condition", "0", "liquid/node").
Edge("UserConditionAssertion", "liquid/mutable", "false").

DefCompound("UserMedicationAssertion", "user/profile", "0", "liquid/node").
DefCompound("UserMedicationAssertion", "user/episode", "0", "liquid/node").
DefCompound("UserMedicationAssertion", "clinical/medication", "0", "liquid/node").
Edge("UserMedicationAssertion", "liquid/mutable", "false").

% Optional materialized joins for downstream applications or review workflows.
DefCompound("UserIndicationMatch", "user/profile", "0", "liquid/node").
DefCompound("UserIndicationMatch", "user/episode", "0", "liquid/node").
DefCompound("UserIndicationMatch", "clinical/medication", "0", "liquid/node").
DefCompound("UserIndicationMatch", "clinical/condition", "0", "liquid/node").
DefCompound("UserIndicationMatch", "clinical/indication", "0", "liquid/node").
Edge("UserIndicationMatch", "liquid/mutable", "false").

DefCompound("UserContraindicationRisk", "user/profile", "0", "liquid/node").
DefCompound("UserContraindicationRisk", "user/episode", "0", "liquid/node").
DefCompound("UserContraindicationRisk", "clinical/medication", "0", "liquid/node").
DefCompound("UserContraindicationRisk", "clinical/condition", "0", "liquid/node").
DefCompound("UserContraindicationRisk", "clinical/contraindication", "0", "liquid/node").
Edge("UserContraindicationRisk", "liquid/mutable", "false").

% --- Class hierarchy ---
Edge("class/Thing", "onto/preferred_label", "Thing").
Edge("class/Thing", "onto/instance_of", "class/Thing").
Edge("class/ClinicalConcept", "onto/preferred_label", "Clinical Concept").
Edge("class/ClinicalConcept", "onto/instance_of", "class/Thing").
Edge("class/ClinicalConcept", "onto/subclass_of", "class/Thing").
Edge("class/Condition", "onto/preferred_label", "Condition").
Edge("class/Condition", "onto/instance_of", "class/Thing").
Edge("class/Condition", "onto/subclass_of", "class/ClinicalConcept").
