{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@datalog/parser": [
        "../parser/src/index.ts"
      ]
    },
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": false,
    "types": [
      "node"
    ]
  },
  "references": [
    {
      "path": "../parser/tsconfig.lib.json"
    }
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
