{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./out-tsc/vitest",
    "paths": {
      "@datalog/ast": [
        "../datalog-ast/src/index.ts"
      ],
      "@datalog/datalog-migrate": [
        "../datalog-migrate/src/index.ts"
      ],
      "@datalog/datalog-migrate/load-datalog-migration-project-files": [
        "../datalog-migrate/src/load-datalog-migration-project-files.ts"
      ],
      "@datalog/parser": [
        "../parser/src/index.ts"
      ]
    },
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "vitest"
    ]
  },
  "references": [
    {
      "path": "../datalog-ast/tsconfig.lib.json"
    },
    {
      "path": "../datalog-migrate/tsconfig.lib.json"
    },
    {
      "path": "../parser/tsconfig.lib.json"
    }
  ],
  "include": [
    "vitest.config.ts",
    "src/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
