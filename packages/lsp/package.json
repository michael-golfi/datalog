{
  "name": "@datalog/lsp",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./semantic-tokens": {
      "types": "./dist/semantic-tokens.d.ts",
      "import": "./dist/semantic-tokens.js",
      "default": "./dist/semantic-tokens.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc -b ./tsconfig.lib.json",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "yarn workspace @datalog/ast build && yarn workspace @datalog/parser build && yarn workspace @datalog/datalog-migrate build && tsc -p ./tsconfig.lib.json --noEmit && tsc -p ./tsconfig.spec.json --noEmit",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@datalog/ast": "workspace:*",
    "@datalog/datalog-migrate": "workspace:*",
    "@datalog/parser": "workspace:*",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-textdocument": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
