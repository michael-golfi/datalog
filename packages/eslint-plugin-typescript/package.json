{
  "name": "@datalog/eslint-plugin-typescript",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint --max-warnings=0 . && yarn typecheck",
    "typecheck": "yarn exec tsc -b tsconfig.json",
    "build": "yarn exec tsc -b tsconfig.lib.json",
    "test": "vitest run --config vitest.config.ts",
    "story": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "eslint": "^9.36.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^3.2.4"
  }
}
