{
  "extends": "../../tsconfig.base.json",
  "references": [
    {
      "path": "../lsp/tsconfig.lib.json"
    }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "build/out",
    "tsBuildInfoFile": "build/tsconfig.build.tsbuildinfo",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "vitest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
