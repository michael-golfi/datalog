{
  "comments": {
    "lineComment": "%"
  },
  "brackets": [
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "(",
      "close": ")",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "(",
      ")"
    ]
  ],
  "wordPattern": "[A-Za-z_][A-Za-z0-9_/@-]*",
  "indentationRules": {
    "increaseIndentPattern": ".*\\($",
    "decreaseIndentPattern": "^\\s*\\)"
  }
}
